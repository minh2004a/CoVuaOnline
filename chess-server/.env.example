PORT=3000
CORS_ORIGIN=*

# Optional custom db location
# CHESS_DB_PATH=./data/chess-online.sqlite

# Matchmaking tuning (rating difference grows with queue wait time)
# MATCH_BASE_RATING_GAP=100
# MATCH_GAP_GROWTH_PER_SECOND=8
# MATCH_MAX_RATING_GAP=600
# MATCHMAKING_TICK_MS=3000

# Firebase Admin (server-side verification)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\"

# Firebase Web SDK config (sent to browser by /api/client-config)
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_WEB_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=your-project-id
FIREBASE_WEB_APP_ID=1:1234567890:web:abcdef123456
# FIREBASE_WEB_MESSAGING_SENDER_ID=1234567890
# FIREBASE_WEB_MEASUREMENT_ID=G-XXXXXXXXXX
